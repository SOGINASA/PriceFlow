# === Flask ===
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# === База данных ===
# Локально (Docker compose поднимает Postgres):
DATABASE_URL=postgresql://medarchive:medarchive@localhost:5432/medarchive
# Быстрый старт без Postgres — закомментируйте строку выше (будет SQLite fallback)

# === Очередь ===
REDIS_URL=redis://localhost:6379/0

# === Нормализация ===
MATCH_AUTO_THRESHOLD=0.85
# Дообучение, уровень 2 — семантический матчинг по эмбеддингам (ВКЛ по умолчанию).
# Модель ~120 МБ скачивается на первом запуске, работает на CPU. Для слабого
# железа можно выключить (false) — останутся точное + нечёткое сопоставление.
SEMANTIC_MATCH_ENABLED=true
# SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# SEMANTIC_THRESHOLD=0.70   # косинус 0..1 для автосопоставления

# === Валидация ===
PRICE_ANOMALY_PCT=0.50

# === OCR (EasyOCR) ===
OCR_LANGS=ru,en          # языки EasyOCR через запятую (ru покрывает кириллицу, в т.ч. казахскую)
OCR_GPU=false            # true — если есть CUDA
OCR_DPI=300              # рендер PDF в картинку перед OCR (300 — чётче мелкий шрифт)

# === Админ-раздел ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=MedArchive@2025

# === LLM-консолидация справочника (дедуп синонимов, ТЗ 4.3) ===
# Ключ Groq (https://console.groq.com). Без ключа /catalog/consolidate
# использует офлайн-нормализацию. Провайдер OpenAI-совместимый.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
